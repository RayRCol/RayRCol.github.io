---
import { render } from 'astro:content';

import EntryLayout from '../../layouts/EntryLayout.astro';
import { formatLongDate } from '../../lib/format';
import { getReportEntries } from '../../lib/content';

export async function getStaticPaths() {
  const reports = await getReportEntries();
  return reports.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  eyebrow={entry.data.label}
  summary={entry.data.summary}
  image={entry.data.image}
  backHref="/reports/"
  backLabel="All reports"
  details={[
    { label: 'Published', value: formatLongDate(entry.data.publishedAt) },
    { label: 'Highlight', value: entry.data.highlight },
    { label: 'Range Start', value: entry.data.rangeStart },
    { label: 'Range End', value: entry.data.rangeEnd },
  ]}
>
  <Content />
</EntryLayout>
