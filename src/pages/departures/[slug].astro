---
import { render } from 'astro:content';

import EntryLayout from '../../layouts/EntryLayout.astro';
import { formatLongDate } from '../../lib/format';
import { getDepartureEntries } from '../../lib/content';

export async function getStaticPaths() {
  const departures = await getDepartureEntries();
  return departures.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EntryLayout
  title={entry.data.title}
  eyebrow="Departure Brief"
  summary={entry.data.detail}
  image={entry.data.image}
  backHref="/departures/"
  backLabel="All departures"
  details={[
    { label: 'Launch Date', value: formatLongDate(entry.data.launchDate) },
    { label: 'Countdown', value: entry.data.countdown },
    { label: 'Launch Site', value: entry.data.launchSite },
    { label: 'Mission Window', value: entry.data.missionWindow },
  ]}
>
  <Content />
</EntryLayout>
